# grouping_ablation_experiment
# dataset(s)=nsl_kdd
# scope=by_label
# seed=42
# anomaly_samples(used when scope=sample)=5
# time=2026-04-10T17:28:43

Variants:
  coarse: fewer, merged behavior groups
  baseline: current NSL config / NetML regex rules
  fine: more groups (NSL splits rates/volume; NetML splits timing)

# nsl_path=C:\Feature_Dev\Dataset\KDDTest.csv rows=22544
# NSL-KDD by_label: single pass over all anomalies; slice_key column = attack label

